{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "platforms": ["windows", "linux", "macOS"],
  "webviews": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "notification:allow-is-permission-granted",
    "log:default",
    "clipboard-manager:allow-read-image",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "shell:allow-open",
    "core:window:allow-destroy",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "core:webview:allow-set-webview-zoom",
    "allow-spawn-pty",
    "allow-spawn-pty-tmux-cc",
    "allow-subscribe-pty-events",
    "allow-write-pty",
    "allow-resize-pty",
    "allow-kill-pty",
    "allow-get-workspace-info",
    "allow-get-ports",
    "allow-get-pty-pid",
    "allow-get-shell-ctx",
    "allow-get-session-metadata",
    "allow-pty-has-agent-process",
    "allow-list-fonts",
    "allow-read-dir",
    "allow-remote-read-dir",
    "allow-start-monitor",
    "allow-stop-monitor",
    "allow-request-session-content",
    "allow-resolve-control-request",
    "allow-check-remote-clis",
    "allow-check-local-clis",
    "allow-check-remote-tmux",
    "allow-desktop-agent-open",
    "allow-desktop-agent-write",
    "allow-desktop-agent-close",
    "allow-desktop-claude-sessions",
    "allow-desktop-claude-session",
    "allow-save-image-locally",
    "allow-push-image-to-remote",
    "allow-tmux-list-sessions",
    "allow-tmux-active-pane-cwd",
    "allow-tmux-switch-client",
    "allow-tmux-new-session",
    "allow-tmux-kill-session",
    "allow-set-workspace-list",
    "allow-send-notification",
    "allow-install-cli-symlink",
    "allow-browser-create",
    "allow-browser-update-bounds",
    "allow-browser-set-visible",
    "allow-browser-close",
    "allow-browser-navigate",
    "allow-browser-reload",
    "allow-browser-current-url",
    "allow-browser-snapshot",
    "allow-browser-console-logs",
    "allow-browser-screenshot"
  ]
}
